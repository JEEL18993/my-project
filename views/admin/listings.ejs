<% layout("layouts/boilerplate") %>

<div class="row mt-4">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h3>Manage Listings</h3>
      <a href="/admin" class="btn btn-outline-dark btn-sm">Admin Home</a>
    </div>

    <div class="table-responsive">
      <table class="table table-bordered align-middle">
        <thead class="table-light">
          <tr>
            <th>Title</th>
            <th>Location</th>
            <th>Price</th>
            <th>Owner</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% for (let listing of listings) { %>
            <tr>
              <td><a href="/listings/<%= listing._id %>"><%= listing.title %></a></td>
              <td><%= listing.location %>, <%= listing.country %></td>
              <td>Rs <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></td>
              <td><%= listing.owner ? listing.owner.username : "No owner" %></td>
              <td>
                <form method="POST" action="/admin/listings/<%= listing._id %>?_method=DELETE">
                  <button class="btn btn-danger btn-sm">Delete</button>
                </form>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
