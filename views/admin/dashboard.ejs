<% layout("layouts/boilerplate") %>

<div class="row mt-4">
  <div class="col-10 offset-1">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3>Admin Panel</h3>
      <a href="/listings" class="btn btn-outline-dark btn-sm">Back to Site</a>
    </div>

    <div class="row">
      <div class="col-md-3 mb-3">
        <div class="card admin-stat-card">
          <div class="card-body">
            <p class="text-muted mb-1">Listings</p>
            <h3><%= listingCount %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <div class="card admin-stat-card">
          <div class="card-body">
            <p class="text-muted mb-1">Users</p>
            <h3><%= userCount %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <div class="card admin-stat-card">
          <div class="card-body">
            <p class="text-muted mb-1">Reviews</p>
            <h3><%= reviewCount %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <div class="card admin-stat-card">
          <div class="card-body">
            <p class="text-muted mb-1">Bookings</p>
            <h3><%= bookingCount %></h3>
          </div>
        </div>
      </div>
    </div>

    <div class="list-group mt-3">
      <a href="/admin/listings" class="list-group-item list-group-item-action">Manage Listings</a>
      <a href="/admin/bookings" class="list-group-item list-group-item-action">Manage Bookings</a>
      <a href="/admin/reviews" class="list-group-item list-group-item-action">Manage Reviews</a>
      <a href="/admin/users" class="list-group-item list-group-item-action">Manage Users</a>
    </div>
  </div>
</div>
