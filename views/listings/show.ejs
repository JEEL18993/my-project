<% layout("layouts/boilerplate") %>

<script src="https://cdn.maptiler.com/maptiler-sdk-js/v2.3.0/maptiler-sdk.umd.min.js"></script>
<link href="https://cdn.maptiler.com/maptiler-sdk-js/v2.3.0/maptiler-sdk.css" rel="stylesheet" />

<%
  const galleryImages = [];
  if (listing.image && listing.image.url) {
    galleryImages.push(listing.image);
  }
  if (listing.images && listing.images.length > 0) {
    for (let image of listing.images) {
      if (image && image.url && !galleryImages.some((img) => img.url === image.url)) {
        galleryImages.push(image);
      }
    }
  }
%>

<div class="row mt-3">
  <div class="col-10 offset-1">
    <h3 class="mb-1"><%= listing.title %></h3>
    <p class="text-muted mb-3">
      Hosted by <%= listing.owner.username %> · <%= listing.location %>, <%= listing.country %>
    </p>

    <% if (galleryImages.length > 0) { %>
      <div class="listing-gallery <%= galleryImages.length === 1 ? 'single-gallery' : '' %> mb-4">
        <img src="<%= galleryImages[0].url %>" class="listing-gallery-main" alt="listing main image">

        <% if (galleryImages.length > 1) { %>
          <div class="listing-gallery-side">
            <% for (let i = 1; i < Math.min(galleryImages.length, 5); i++) { %>
              <img src="<%= galleryImages[i].url %>" class="listing-gallery-thumb" alt="listing gallery image">
            <% } %>
          </div>
        <% } %>
      </div>
    <% } %>

    <div class="listing-detail-row mb-4">
      <div>
        <h4>About this stay</h4>
        <p class="listing-description"><%= listing.description %></p>
      </div>

      <div class="listing-price-box">
        <p class="mb-1 text-muted">Starting from</p>
        <h4>Rs <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></h4>
        <p class="mb-0 text-muted">per night</p>
      </div>
    </div>
  </div>

  <% if(currentUser && listing.owner._id.equals(currentUser._id)) { %>
    <div class="btns col-10 offset-1 mb-5">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit</a>
      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
        <button class="btn btn-danger ms-3">Delete</button>
      </form>
    </div>
  <% } %>

  <div class="col-10 offset-1 mb-3">
    <hr>
    <h4>Book this stay</h4>

    <% if(currentUser && !listing.owner._id.equals(currentUser._id)) { %>
      <form action="/listings/<%= listing._id %>/bookings" method="POST" class="needs-validation" novalidate>
        <div class="row">
          <div class="mb-3 col-md-4">
            <label for="checkIn" class="form-label">Check-in</label>
            <input type="date" name="booking[checkIn]" id="checkIn" class="form-control" required>
            <div class="invalid-feedback">Please select a check-in date.</div>
          </div>

          <div class="mb-3 col-md-4">
            <label for="checkOut" class="form-label">Check-out</label>
            <input type="date" name="booking[checkOut]" id="checkOut" class="form-control" required>
            <div class="invalid-feedback">Please select a check-out date.</div>
          </div>

          <div class="mb-3 col-md-4">
            <label for="guests" class="form-label">Guests</label>
            <input type="number" name="booking[guests]" id="guests" min="1" value="1" class="form-control" required>
            <div class="invalid-feedback">Please enter number of guests.</div>
          </div>
        </div>

        <div class="mb-3">
          <label for="paymentMethod" class="form-label">Payment Method</label>
          <select name="booking[paymentMethod]" id="paymentMethod" class="form-select" required>
            <option value="card">Card Demo Payment</option>
            <option value="upi">UPI Demo Payment</option>
            <option value="netbanking">Net Banking Demo Payment</option>
            <option value="cash">Pay At Property</option>
          </select>
        </div>

        <p class="text-muted">
          Price: Rs <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> / night
        </p>
        <button class="btn btn-danger">Book Now</button>
      </form>
    <% } else if(currentUser && listing.owner._id.equals(currentUser._id)) { %>
      <p class="text-muted">You are the owner of this listing.</p>
    <% } else { %>
      <p class="text-muted">Please log in to book this stay.</p>
      <a href="/login" class="btn btn-dark">Log in</a>
    <% } %>
  </div>

  <div class="col-10 offset-1 mb-3">
    <% if(currentUser) { %>
      <hr>
      <h4>Leave a Review</h4>
      <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
        <div class="mb-3 mt-3">
          <label class="form-label">Rating</label>
          <fieldset class="starability-slot">
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
          </fieldset>
        </div>

        <div class="mb-3 mt-3">
          <label for="comment" class="form-label">Comment</label>
          <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
          <div class="invalid-feedback">Please submit some comments for review</div>
        </div>
        <button class="btn btn-outline-dark">Submit</button>
      </form>
    <% } %>

    <% if(listing.reviews.length > 0) { %>
      <hr>
      <p><b>All Reviews</b></p>
      <div class="row">
        <% for(let review of listing.reviews) { %>
          <div class="card col-md-5 ms-3 mb-3">
            <div class="card-body">
              <h5 class="card-title">@<%= review.author.username %></h5>
              <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
              <p class="card-text"><%= review.comment %></p>
              <% if(currentUser && review.author._id.equals(currentUser._id)) { %>
                <form class="mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                  <button class="btn btn-sm btn-danger">Delete</button>
                </form>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>

  <div class="col-10 offset-1 mb-3">
    <hr>
    <h4>Where you'll be</h4>
    <div id="map" style="height: 400px; width: 100%; border-radius: 15px; border: 1px solid #ddd;"></div>
  </div>
</div>

<script>
  const mapToken = "<%= process.env.MAPTILER_API_KEY || 'eIOfAmUriGHfSPBMGcpG' %>";
  const coordinates = <%- listing.geometry && listing.geometry.coordinates ? JSON.stringify(listing.geometry.coordinates) : "null" %>;
  const listingLocation = "<%= listing.location %>";
  const mapCenter = (coordinates && coordinates.length === 2) ? coordinates : [78.9629, 20.5937];

  maptilersdk.config.apiKey = mapToken;
  const map = new maptilersdk.Map({
    container: "map",
    style: maptilersdk.MapStyle.STREETS,
    center: mapCenter,
    zoom: 9
  });

  if (coordinates && coordinates.length === 2) {
    new maptilersdk.Marker({ color: "#FF385C" })
      .setLngLat(mapCenter)
      .setPopup(
        new maptilersdk.Popup({ offset: 25 })
          .setHTML(`<h5>${listingLocation}</h5><p>Exact location provided after booking.</p>`)
      )
      .addTo(map);
  }
</script>
